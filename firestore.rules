rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor' && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'saidibrahimu38@gmail.com'
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'saidibrahimu38@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'email', 'role', 'isApproved', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 60 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['user', 'vendor', 'admin'] &&
             (data.role == 'user' || data.role == 'vendor') && 
             (data.role == 'user' ? data.isApproved == true : data.isApproved == false) &&
             data.createdAt == request.time;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name']) &&
             data.keys().size() == 1 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'stock', 'categoryId', 'createdAt', 'description', 'imageUrl', 'vendorId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price > 0 &&
             data.stock is int && data.stock >= 0 &&
             data.categoryId is string &&
             data.description is string &&
             data.imageUrl is string &&
             data.vendorId is string &&
             data.createdAt == request.time;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'totalPrice', 'status', 'createdAt', 'items']) &&
             data.userId == request.auth.uid &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.items is list &&
             data.createdAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'username', 'rating', 'comment', 'createdAt']) &&
             data.productId is string &&
             data.userId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt == request.time;
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) || isSuperAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCategory(incoming());
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && incoming().vendorId == request.auth.uid;
      allow update: if isAdmin() && (resource.data.vendorId == request.auth.uid || isSuperAdmin());
      allow delete: if isAdmin() && (resource.data.vendorId == request.auth.uid || isSuperAdmin());
    }

    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isSignedIn() && (
        // Admin can update status
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // User can cancel if pending
        (isOwner(existing().userId) && existing().status == 'pending' && 
         incoming().status == 'cancelled' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    match /orders/{orderId}/items/{itemId} {
      allow read: if isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.userId) || isAdmin();
      allow create: if isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.userId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
